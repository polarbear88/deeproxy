# ===== 编译产物 =====
# 本项目可执行文件（交叉编译可能产出带平台后缀的文件）
/deeproxy
/deeproxy.exe
deeproxy_*           # 例如 deeproxy_linux_amd64
*.exe
*.dll
*.so
*.dylib

# Go 测试/覆盖率产物
*.test
*.out
coverage.txt
coverage.html

# Go 工作区文件（本地开发用，不应提交）
go.work
go.work.sum

# ===== OMC 工具运行时状态 =====
# .omc/state 为会话级临时状态（PRD、session、HUD 等），属于运行时产物，不入库；
# 计划与规格（.omc/plans、.omc/specs）作为文档保留，可手动 git add。
.omc/state/
.omc/logs/
.omc/research/

# ralph 会话工作笔记
progress.txt

# ===== 操作系统/编辑器 =====
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*~


test_config.yaml

# OMC 项目记忆（工具自动生成的状态，不应入库）
.omc/project-memory.json

# OMC 会话状态（工具自动生成）
.omc/sessions/
web/.omc/state/sessions/
web/src/.omc/state/sessions/
web/.omc/state
web/src/.omc/state

# ===== 前端（web/）=====
# 依赖与构建缓存不入库
web/node_modules/
web/dist/
web/.vite/
# 前端构建产物输出到 api/dist 供 Go embed；产物由 CI/本地构建生成，不入库，
# 但保留占位文件（.gitkeep 与 index.html）保证未构建时 go:embed 仍可编译（计划 M2）。
api/dist/assets/
api/dist/favicon.svg

#===== 构建产物 =====
# 注意：此规则会匹配任意层级的 dist/（含 api/dist）。下面用例外规则放行
# api/dist 的 embed 占位文件（index.html / .gitkeep），保证全新 clone 后
# //go:embed all:dist 仍能编译（assets 等真实产物仍由上面 api/dist/assets/ 忽略）。
dist/
!api/dist/
api/dist/*
!api/dist/.gitkeep
deeproxy.db
deeproxy.db-*
